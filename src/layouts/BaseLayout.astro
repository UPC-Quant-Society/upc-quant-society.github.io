---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getAlternatePath, type Lang } from '../data/site';

type Props = {
  lang: Lang;
  title: string;
  description: string;
  slug?: string;
};

const { lang, title, description, slug } = Astro.props;
const fullTitle = title === 'UPC Quant Society' ? title : `${title} · UPC Quant Society`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const alternate = new URL(getAlternatePath(lang, slug), Astro.site);
const catalanUrl = lang === 'ca' ? canonical : alternate;
const englishUrl = lang === 'en' ? canonical : alternate;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#111111" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ca" href={catalanUrl} />
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">
      {lang === 'ca' ? 'Ves al contingut' : 'Skip to content'}
    </a>
    <Header lang={lang} slug={slug} />
    <main id="main-content">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
