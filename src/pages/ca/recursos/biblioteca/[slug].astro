---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const resources = await getCollection('resources');

  return resources.map((resource) => ({
    params: {
      slug: resource.data.slug,
    },
    props: {
      resource,
    },
  }));
}

const { resource } = Astro.props;
const data = resource.data;

const hasDetailedScore =
  data.score.quality !== undefined &&
  data.score.pedagogy !== undefined &&
  data.score.quantRelevance !== undefined &&
  data.score.practicalValue !== undefined &&
  data.score.reputation !== undefined &&
  data.score.currency !== undefined &&
  data.score.accessibility !== undefined;

const detailedScore = hasDetailedScore
  ? 0.25 * data.score.quality! +
    0.20 * data.score.pedagogy! +
    0.20 * data.score.quantRelevance! +
    0.15 * data.score.practicalValue! +
    0.10 * data.score.reputation! +
    0.05 * data.score.currency! +
    0.05 * data.score.accessibility!
  : undefined;

const finalScore =
  data.score.overall ??
  detailedScore ??
  0;
---

<BaseLayout
  lang="ca"
  slug={`recursos/biblioteca/${data.slug}`}
  title={data.title}
  description={data.description.ca}
>
  <div class="shell resource-detail">
    <a href="/ca/recursos/biblioteca/">
      ← Tornar a la biblioteca
    </a>

    <header>
      <p class="eyebrow">{data.type}</p>

      <h1>{data.title}</h1>

      <p>{data.description.ca}</p>
    </header>

    <dl>
      {
        data.institution && (
          <div>
            <dt>Institució</dt>
            <dd>{data.institution}</dd>
          </div>
        )
      }

      <div>
        <dt>Nivell</dt>
        <dd>{data.levels.join(', ')}</dd>
      </div>

      <div>
        <dt>Accés</dt>
        <dd>{data.access}</dd>
      </div>

      <div>
        <dt>Puntuació</dt>
        <dd>{finalScore.toFixed(1)}/10</dd>
      </div>

      <div>
        <dt>Idiomes</dt>
        <dd>{data.languages.join(', ')}</dd>
      </div>

      <div>
        <dt>Tipus</dt>
        <dd>{data.type}</dd>
      </div>
    </dl>

    <a
      class="button button-primary"
      href={data.officialUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      Obrir el recurs oficial
    </a>
  </div>
</BaseLayout>