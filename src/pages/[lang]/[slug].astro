---
import ContentPage from '../../components/ContentPage.astro';
import { pages, type Lang } from '../../data/site';

export function getStaticPaths() {
  return (Object.keys(pages) as Lang[]).flatMap((lang) =>
    Object.entries(pages[lang]).map(([slug, page]) => ({
      params: { lang, slug },
      props: { lang, slug, page },
    })),
  );
}

const { lang, slug, page } = Astro.props;
---

<ContentPage lang={lang} slug={slug} page={page} />
