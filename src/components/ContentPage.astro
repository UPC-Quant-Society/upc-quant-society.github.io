---
import BaseLayout from '../layouts/BaseLayout.astro';
import KnowledgeGraph from './library/KnowledgeGraph.astro';
import type { Lang, PageData } from '../data/site';
import { ui } from '../data/site';

type Props = {
  lang: Lang;
  slug: string;
  page: PageData;
};

const { lang, slug, page } = Astro.props;
const t = ui[lang];

const showKnowledgeGraph =
  slug === 'recursos' || slug === 'resources';

const graphTitle =
  lang === 'ca'
    ? 'Explora el mapa de coneixement'
    : 'Explore the knowledge map';

const graphDescription =
  lang === 'ca'
    ? 'Visualitza les àrees i els recursos de la biblioteca i descobreix com es connecten entre si.'
    : 'Visualise the library areas and resources and discover how they connect.';
---

<BaseLayout
  lang={lang}
  slug={slug}
  title={page.title}
  description={page.description}
>
  <section class="page-hero shell">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>{page.title}</h1>
    <p class="page-intro">{page.intro}</p>
  </section>

  {
    showKnowledgeGraph && (
      <section
        class="shell resources-graph-section"
        id="knowledge-graph"
      >
        <div class="section-heading">
          <span class="section-number">00</span>
          <h2>{graphTitle}</h2>
        </div>

        <p class="resources-graph-intro">
          {graphDescription}
        </p>

        <KnowledgeGraph lang={lang} />
      </section>
    )
  }

  <div class="page-layout shell">
    <aside class="page-index">
      <span>{t.onThisPage}</span>

      <nav aria-label={t.onThisPage}>
        {
          showKnowledgeGraph && (
            <a href="#knowledge-graph">
              {lang === 'ca'
                ? 'Mapa de coneixement'
                : 'Knowledge map'}
            </a>
          )
        }

        {
          page.sections.map((section) => (
            <a href={`#${section.id}`}>
              {section.title}
            </a>
          ))
        }
      </nav>
    </aside>

    <div class="page-sections">
      {
        page.sections.map((section) => (
          <section
            class="content-section"
            id={section.id}
          >
            <div class="section-heading">
              {
                section.kicker && (
                  <span class="section-number">
                    {section.kicker}
                  </span>
                )
              }

              <h2>{section.title}</h2>
            </div>

            {
              section.body && (
                <div class="body-copy">
                  {
                    section.body.map((paragraph) => (
                      <p>{paragraph}</p>
                    ))
                  }
                </div>
              )
            }

            {
              section.cards && (
                <div
                  class:list={[
                    'card-grid',
                    {
                      'three-columns':
                        section.cards.length === 3,
                    },
                  ]}
                >
                  {
                    section.cards.map((card) => (
                      <article
                        class:list={[
                          'info-card',
                          {
                            linked: Boolean(card.href),
                          },
                        ]}
                      >
                        {
                          card.status && (
                            <span class="status">
                              {card.status}
                            </span>
                          )
                        }

                        {
                          card.label && (
                            <span class="card-label">
                              {card.label}
                            </span>
                          )
                        }

                        <h3>{card.title}</h3>
                        <p>{card.text}</p>

                        {
                          card.href && (
                            <a
                              href={card.href}
                              aria-label={`${t.viewPage}: ${card.title}`}
                            >
                              {t.viewPage}
                              <span aria-hidden="true">
                                {' '}↗
                              </span>
                            </a>
                          )
                        }
                      </article>
                    ))
                  }
                </div>
              )
            }

            {
              section.people && (
                <div class="people-grid">
                  {
                    section.people.map((person) => (
                      <article class="person-card">
                        <div
                          class="person-initials"
                          aria-hidden="true"
                        >
                          {
                            person.name
                              .split(' ')
                              .slice(0, 2)
                              .map((part) => part[0])
                              .join('')
                          }
                        </div>

                        <div>
                          <span>{person.role}</span>
                          <h3>{person.name}</h3>
                          <p>{person.description}</p>
                        </div>
                      </article>
                    ))
                  }
                </div>
              )
            }

            {
              section.note && (
                <div
                  class:list={[
                    'note',
                    section.note.tone === 'green'
                      ? 'note-green'
                      : 'note-neutral',
                  ]}
                >
                  <span>
                    {
                      section.note.tone === 'green'
                        ? '//'
                        : '—'
                    }
                  </span>

                  <div>
                    <h3>{section.note.title}</h3>
                    <p>{section.note.text}</p>
                  </div>
                </div>
              )
            }

            {
              section.cta && (
                <a
                  class="button button-primary"
                  href={section.cta.href}
                >
                  {section.cta.label}
                </a>
              )
            }
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>